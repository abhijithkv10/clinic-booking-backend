const PORT = process.env.PORT || 5000;

app.listen(PORT, "0.0.0.0", () => {
  console.log(`✅ Server running on port ${PORT}`);

  setTimeout(() => runSlotGeneration("STARTUP"), 3000);
  cron.schedule("1 * * * *", () => runSlotGeneration("CRON"));
  console.log("📅 Slot auto-generation: on startup + every hour at :01");

  // Transfer release cron — runs every hour at :30
  // Finds bookings with on_hold transfers where paidAt >= 6 days ago
  // and releases them so the consultation fee goes to the clinic account
  cron.schedule("30 * * * *", async () => {
    console.log("\n⏰ [TRANSFER RELEASE CRON] Checking for on-hold transfers to release…");
    try {
      await releaseOnHoldTransfers();
    } catch (err) {
      console.error("❌ [TRANSFER RELEASE CRON] Error:", err.message);
    }
  });
  console.log("💸 Transfer release cron: every hour at :30 (releases after 6 days)");

  // Push notification cron — every minute
  if (process.env.VAPID_PUBLIC_KEY) {
    cron.schedule("* * * * *", runPushNotifications);
    console.log("🔔 Push notification cron: every minute");
  }
});
