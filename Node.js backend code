/* SLOT CONTROLLER — for cron + startup */
const { autoGenerateSlotsCore } = require("./controllers/slotController");

/* PAYMENT CONTROLLER — for transfer release cron */
const { releaseOnHoldTransfers } = require("./controllers/paymentController");
